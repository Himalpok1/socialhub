# SocialHub Backend — Production Environment Variables
# Copy this to .env and fill in real values

NODE_ENV=production
PORT=5001

# MongoDB Atlas — get this from https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/socialhub?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/socialhub?retryWrites=true&w=majority

# Redis — installed on VPS at localhost
REDIS_URL=redis://localhost:6379

# JWT — use a long random string (generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=7d

# Demo Mode — set to false in production to use real APIs
DEMO_MODE=false

# Cloudinary — https://cloudinary.com (free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Facebook / Instagram — https://developers.facebook.com
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=https://yourdomain.com/api/accounts/callback/facebook

# TikTok — https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://yourdomain.com/api/accounts/callback/tiktok

# Frontend URL — for CORS (your actual domain)
FRONTEND_URL=https://yourdomain.com
